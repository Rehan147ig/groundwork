GROUNDWORK_ENV=local

# Console
NEXT_PUBLIC_APP_NAME=Groundwork
QUERY_RUNTIME_URL=http://localhost:8080
INGESTION_RUNTIME_URL=http://localhost:8090
EMBEDDING_URL=http://localhost:8090
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=/models/fastembed

# Runtime security
IDK_THRESHOLD=0.70
ACL_TIMEOUT_MS=120
QUERY_TIMEOUT_MS=250
IMMUTABLE_AUDIT_SALT=change-me

# Multi-region tenant controls
DEFAULT_RESIDENCY=uk
US_REGION=us-central1
EU_REGION=europe-west1
UK_REGION=europe-west2

# Data systems
POSTGRES_URL=postgres://groundwork:groundwork@localhost:5432/groundwork
QDRANT_URL=http://localhost:6333
ELASTICSEARCH_URL=http://localhost:9200
OBJECT_STORAGE_ENDPOINT=http://localhost:9000

# Microsoft 365 / SharePoint OAuth schema
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_REDIRECT_URI=http://localhost:3000/api/connectors/microsoft/callback

# Microsoft Graph Pilot (optional)
# Set these to enable `make connector-enumerate`. See
# services/msgraph-connector/README.md for the Azure app-registration steps.
# The connector requests only the four read-only application scopes documented
# there; no write scope is ever requested.
MSGRAPH_TENANT_ID=
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
OPENFGA_STORE_ID=
