# Vercel environment for apps/console.
#
# TIER 0 (instant link): set NONE of these. Every /api route falls back to the
# curated Acme demo data, which is identical to what the live runtime produces.
# Import the repo into Vercel (root directory = apps/console) and deploy.
#
# TIER 1+ (live backend): set the four variables below in the Vercel project
# (Project Settings -> Environment Variables). GROUNDWORK_JWT_HS_SECRET and
# GROUNDWORK_API_KEY MUST exactly match the runtime's values, or JWT minting and
# API-key auth will fail and the console will fall back to demo data.

# Public URL of the Fly runtime (Tier 1+). Leave blank for Tier 0.
QUERY_RUNTIME_URL=https://groundwork-runtime.fly.dev

# Must equal the runtime's BOOTSTRAP_API_KEY secret.
GROUNDWORK_API_KEY=gw_live_<random>

# Must equal the runtime's GROUNDWORK_JWT_HS_SECRET secret (HS256). The console
# mints short-lived user assertions with this; the runtime verifies them.
GROUNDWORK_JWT_HS_SECRET=<32+ byte random string — identical to the runtime>

# Cosmetic.
NEXT_PUBLIC_APP_NAME=Groundwork
